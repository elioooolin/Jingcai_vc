<!-- pages/phone-binding/phone-binding.wxml -->
<view class="phone-binding-container">
  <!-- 头部说明 -->
  <view class="header-section">
    <view class="logo-wrapper">
      <image 
        class="logo-image" 
        src="{{brandLogoPath}}" 
        mode="aspectFit"
      />
    </view>
    
    <view class="brand-info">
      <text class="brand-title">{{brandDisplayName}}</text>
    </view>
    
  <view class="binding-info">
      <text class="binding-desc">首次登录，请优先使用微信手机号一键绑定已登记客户账号</text>
  </view>
  </view>

  <!-- 微信手机号一键绑定 -->
  <view class="input-section">
    <t-button
      theme="primary"
      size="large"
      block
      loading="{{bindingLoading}}"
      openType="getPhoneNumber"
      bind:getphonenumber="handleGetPhoneNumber"
      class="bind-button"
    >
      <text wx:if="{{!bindingLoading}}">微信手机号一键绑定</text>
      <text wx:else>绑定中...</text>
    </t-button>
  </view>

  <!-- 手动输入手机号备用方式 -->
  <view class="tip-section">
    <view class="tip-card secondary-tip-card">
      <text class="tip-title">备用绑定方式</text>
      <text class="tip-content">
        • 如微信手机号授权失败，可手动输入已登记手机号绑定
        • 每个手机号只能绑定一个微信账号
      </text>
    </view>
  </view>

  <view class="input-section manual-section">
    <view class="input-wrapper">
      <t-input
        type="number"
        placeholder="请输入已登记手机号"
        value="{{phone}}"
        bind:change="onPhoneChange"
        maxlength="11"
        class="phone-input"
      />
    </view>
    
    <t-button
      theme="primary"
      size="large"
      block
      loading="{{bindingLoading}}"
      disabled="{{!isPhoneValid || bindingLoading}}"
      bind:tap="handleBindPhone"
      class="bind-button"
    >
      <text wx:if="{{!bindingLoading}}">确认绑定</text>
      <text wx:else>绑定中...</text>
    </t-button>
  </view>

  <!-- 提示信息 -->
  <view class="tip-section">
    <view class="tip-card">
      <text class="tip-title">温馨提示</text>
      <text class="tip-content">
        • 仅已登记客户可完成绑定
        • 如手机号未登记，请联系工作人员
      </text>
    </view>
  </view>
</view>

<!-- 错误提示弹窗 -->
<t-dialog
  visible="{{errorDialogVisible}}"
  title="{{errorDialogTitle}}"
  content="{{errorDialogContent}}"
  confirm-btn="我知道了"
  bind:confirm="closeErrorDialog"
  bind:close="closeErrorDialog"
/>

<!-- 联系客服弹窗 -->
<t-dialog
  visible="{{contactDialogVisible}}"
  title="联系客服"
  content="您的手机号未在系统中登记，请联系工作人员为您添加信息。"
  confirm-btn="我知道了"
  bind:confirm="closeContactDialog"
  bind:close="closeContactDialog"
/>
