<!-- pages/phone-binding/phone-binding.wxml -->
<view class="phone-binding-container">
  <!-- 头部说明 -->
  <view class="header-section">
    <view class="logo-wrapper">
      <image 
        class="logo-image" 
        src="/assets/icons/logo_reverse_lm.svg" 
        mode="aspectFit"
      />
    </view>
    
    <view class="brand-info">
      <text class="brand-title">爱睦 Love Moon</text>
    </view>
    
    <view class="binding-info">
      <text class="binding-desc">首次登录，请通过邀请码绑定您的客户账号</text>
    </view>
  </view>

  <!-- 手机号输入区域 -->
  <view class="input-section">
    <view class="input-wrapper">
      <t-input
        type="number"
        placeholder="请输入内部邀请码"
        value="{{phone}}"
        bind:change="onPhoneChange"
        maxlength="11"
        class="phone-input"
      />
    </view>
    
    <t-button
      theme="primary"
      size="large"
      block
      loading="{{bindingLoading}}"
      disabled="{{!isPhoneValid || bindingLoading}}"
      bind:tap="handleBindPhone"
      class="bind-button"
    >
      <text wx:if="{{!bindingLoading}}">确认绑定</text>
      <text wx:else>绑定中...</text>
    </t-button>
  </view>

  <!-- 提示信息 -->
  <view class="tip-section">
    <view class="tip-card">
      <text class="tip-title">温馨提示</text>
      <text class="tip-content">
        • 如邀请码错误，请联系工作人员
        • 每个邀请码只能绑定一个微信账号
      </text>
    </view>
  </view>
</view>

<!-- 错误提示弹窗 -->
<t-dialog
  visible="{{errorDialogVisible}}"
  title="{{errorDialogTitle}}"
  content="{{errorDialogContent}}"
  confirm-btn="我知道了"
  bind:confirm="closeErrorDialog"
  bind:close="closeErrorDialog"
/>

<!-- 联系客服弹窗 -->
<t-dialog
  visible="{{contactDialogVisible}}"
  title="联系客服"
  content="您的手机号未在系统中注册，请联系工作人员为您添加信息。"
  confirm-btn="我知道了"
  bind:confirm="closeContactDialog"
  bind:close="closeContactDialog"
/>
