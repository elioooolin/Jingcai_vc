<view class="page-container">

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在获取菜单数据...</text>
  </view>

  <!-- 菜单加载失败状态 -->
  <view class="error-container" wx:if="{{!loading && menuLoadError}}">
    <view class="error-icon">⚠️</view>
    <text class="error-title">菜单加载失败</text>
    <text class="error-message">{{menuErrorMessage}}</text>
    <view class="error-actions">
      <button class="retry-button" bind:tap="retryLoadMenu">重新加载</button>
      <button class="contact-button" bind:tap="contactService">联系客服</button>
    </view>
  </view>

  <!-- 菜单内容 -->
  <view class="menu-content" wx:if="{{!loading && !menuLoadError}}">

    <!-- 操作提示 -->
    <view class="tips-container">
      <view class="tips-icon">💡</view>
      <view class="tips-content">
        <text class="tips-text">点击菜品图片查看详细信息，点击菜品名称选择菜品</text>
      </view>
    </view>

    <!-- 早餐 -->
    <view class="meal-section" wx:if="{{breakfastMenu.length > 0}}">
      <view class="meal-title">
        <text class="meal-title-icon">🌅</text>
        <text>早餐</text>
      </view>
      <view class="meal-requirement">
        {{breakfastRule}}（必选）
      </view>
      <view class="menu-grid">
        <view 
          wx:for="{{breakfastMenu}}" 
          wx:key="id"
          class="menu-item {{item.selected ? 'selected' : ''}}"
        >
          <view class="dish-image-container">
            <image 
              class="dish-image" 
              src="{{item.imageUrl}}" 
              mode="aspectFill"
              bind:tap="goToDishDetail"
              bind:error="onImageError"
              bind:load="onImageLoad"
              data-dish-id="{{item.id}}"
              data-name="{{item.name}}"
              lazy-load="{{true}}"
              show-menu-by-longpress="{{false}}"
            />
            <view class="selected-overlay" wx:if="{{item.selected}}">
              <text class="check-icon">✓</text>
            </view>
          </view>
          <view 
            class="dish-name-container"
            bind:tap="selectMenuItem"
            data-meal="breakfast"
            data-id="{{item.id}}"
            data-index="{{index}}"
          >
            <text class="dish-name">{{item.name}}</text>
            <view class="select-indicator {{item.selected ? 'selected' : ''}}">
              <text class="select-icon">{{item.selected ? '✓' : '+'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 午餐 -->
    <view class="meal-section" wx:if="{{lunchMainMenu.length > 0 || lunchSoupMenu.length > 0}}">
      <view class="meal-title">
        <text class="meal-title-icon">🌞</text>
        <text>午餐</text>
      </view>
      <view class="meal-requirement">
        <text wx:if="{{lunchMainRule}}">主菜{{lunchMainRule}}</text>
        <text wx:if="{{lunchMainRule && lunchSoupRule}}">、</text>
        <text wx:if="{{lunchSoupRule}}">汤品{{lunchSoupRule}}</text>
        <text>（必选）</text>
      </view>
      
      <!-- 午餐主菜 -->
      <view class="sub-category" wx:if="{{lunchMainMenu.length > 0}}">
        <text class="sub-category-title">主菜</text>
        <view class="menu-grid">
        <view 
          wx:for="{{lunchMainMenu}}" 
          wx:key="id"
          class="menu-item {{item.selected ? 'selected' : ''}}"
        >
          <view class="dish-image-container">
            <image 
              class="dish-image" 
              src="{{item.imageUrl}}" 
              mode="aspectFill"
              bind:tap="goToDishDetail"
              bind:error="onImageError"
              bind:load="onImageLoad"
              data-dish-id="{{item.id}}"
              data-name="{{item.name}}"
              lazy-load="{{true}}"
              show-menu-by-longpress="{{false}}"
            />
            <view class="selected-overlay" wx:if="{{item.selected}}">
              <text class="check-icon">✓</text>
            </view>
          </view>
          <view 
            class="dish-name-container"
            bind:tap="selectMenuItem"
            data-meal="lunchMain"
            data-id="{{item.id}}"
            data-index="{{index}}"
          >
            <text class="dish-name">{{item.name}}</text>
            <view class="select-indicator {{item.selected ? 'selected' : ''}}">
              <text class="select-icon">{{item.selected ? '✓' : '+'}}</text>
            </view>
          </view>
          </view>
        </view>
      </view>

      <!-- 午餐汤品 -->
      <view class="sub-category" wx:if="{{lunchSoupMenu.length > 0}}">
        <text class="sub-category-title">汤品</text>
        <view class="menu-grid">
          <view 
          wx:for="{{lunchSoupMenu}}" 
          wx:key="id"
          class="menu-item {{item.selected ? 'selected' : ''}}"
        >
          <view class="dish-image-container">
            <image 
              class="dish-image" 
              src="{{item.imageUrl}}" 
              mode="aspectFill"
              bind:tap="goToDishDetail"
              bind:error="onImageError"
              bind:load="onImageLoad"
              data-dish-id="{{item.id}}"
              data-name="{{item.name}}"
              lazy-load="{{true}}"
              show-menu-by-longpress="{{false}}"
            />
            <view class="selected-overlay" wx:if="{{item.selected}}">
              <text class="check-icon">✓</text>
            </view>
            </view>
          <view 
            class="dish-name-container"
            bind:tap="selectMenuItem"
            data-meal="lunchSoup"
            data-id="{{item.id}}"
            data-index="{{index}}"
          >
            <text class="dish-name">{{item.name}}</text>
            <view class="select-indicator {{item.selected ? 'selected' : ''}}">
              <text class="select-icon">{{item.selected ? '✓' : '+'}}</text>
            </view>
          </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 晚餐 -->
    <view class="meal-section" wx:if="{{dinnerMainMenu.length > 0 || dinnerSoupMenu.length > 0}}">
      <view class="meal-title">
        <text class="meal-title-icon">🌙</text>
        <text>晚餐</text>
      </view>
      <view class="meal-requirement">
        <text wx:if="{{dinnerMainRule}}">主菜{{dinnerMainRule}}</text>
        <text wx:if="{{dinnerMainRule && dinnerSoupRule}}">、</text>
        <text wx:if="{{dinnerSoupRule}}">汤品{{dinnerSoupRule}}</text>
        <text>（必选）</text>
      </view>
      
      <!-- 晚餐主菜 -->
      <view class="sub-category" wx:if="{{dinnerMainMenu.length > 0}}">
        <text class="sub-category-title">主菜</text>
        <view class="menu-grid">
          <view 
          wx:for="{{dinnerMainMenu}}" 
          wx:key="id"
          class="menu-item {{item.selected ? 'selected' : ''}}"
        >
          <view class="dish-image-container">
            <image 
              class="dish-image" 
              src="{{item.imageUrl}}" 
              mode="aspectFill"
              bind:tap="goToDishDetail"
              bind:error="onImageError"
              bind:load="onImageLoad"
              data-dish-id="{{item.id}}"
              data-name="{{item.name}}"
              lazy-load="{{true}}"
              show-menu-by-longpress="{{false}}"
            />
            <view class="selected-overlay" wx:if="{{item.selected}}">
              <text class="check-icon">✓</text>
            </view>
            </view>
          <view 
            class="dish-name-container"
            bind:tap="selectMenuItem"
            data-meal="dinnerMain"
            data-id="{{item.id}}"
            data-index="{{index}}"
          >
            <text class="dish-name">{{item.name}}</text>
            <view class="select-indicator {{item.selected ? 'selected' : ''}}">
              <text class="select-icon">{{item.selected ? '✓' : '+'}}</text>
            </view>
          </view>
          </view>
        </view>
      </view>
      
      <!-- 晚餐汤品 -->
      <view class="sub-category" wx:if="{{dinnerSoupMenu.length > 0}}">
        <text class="sub-category-title">汤品</text>
        <view class="menu-grid">
          <view 
          wx:for="{{dinnerSoupMenu}}" 
          wx:key="id"
          class="menu-item {{item.selected ? 'selected' : ''}}"
        >
          <view class="dish-image-container">
            <image 
              class="dish-image" 
              src="{{item.imageUrl}}" 
              mode="aspectFill"
              bind:tap="goToDishDetail"
              bind:error="onImageError"
              bind:load="onImageLoad"
              data-dish-id="{{item.id}}"
              data-name="{{item.name}}"
              lazy-load="{{true}}"
              show-menu-by-longpress="{{false}}"
            />
            <view class="selected-overlay" wx:if="{{item.selected}}">
              <text class="check-icon">✓</text>
            </view>
            </view>
          <view 
            class="dish-name-container"
            bind:tap="selectMenuItem"
            data-meal="dinnerSoup"
            data-id="{{item.id}}"
            data-index="{{index}}"
          >
            <text class="dish-name">{{item.name}}</text>
            <view class="select-indicator {{item.selected ? 'selected' : ''}}">
              <text class="select-icon">{{item.selected ? '✓' : '+'}}</text>
            </view>
          </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 高补餐 -->
    <view class="meal-section" wx:if="{{showSupplementSection && supplementMenu.length > 0}}">
      <view class="meal-title">
        <text class="meal-title-icon">🍎</text>
        <text>高补餐</text>
      </view>
      <view class="meal-requirement">
        {{supplementRule}}（可选）
      </view>
      <view class="menu-grid">
        <view 
          wx:for="{{supplementMenu}}" 
          wx:key="id"
          class="menu-item {{item.selected ? 'selected' : ''}}"
        >
          <view class="dish-image-container">
            <image 
              class="dish-image" 
              src="{{item.imageUrl}}" 
              mode="aspectFill"
              bind:tap="goToDishDetail"
              bind:error="onImageError"
              bind:load="onImageLoad"
              data-dish-id="{{item.id}}"
              data-name="{{item.name}}"
              lazy-load="{{true}}"
              show-menu-by-longpress="{{false}}"
            />
            <view class="selected-overlay" wx:if="{{item.selected}}">
              <text class="check-icon">✓</text>
            </view>
          </view>
          <view 
            class="dish-name-container"
            bind:tap="selectMenuItem"
            data-meal="supplement"
            data-id="{{item.id}}"
            data-index="{{index}}"
          >
            <text class="dish-name">{{item.name}}</text>
            <view class="select-indicator {{item.selected ? 'selected' : ''}}">
              <text class="select-icon">{{item.selected ? '✓' : '+'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 特殊需求 -->
    <view class="card">
      <t-textarea
        label="特殊需求"
        placeholder="请填写特殊需求，如少盐、不吃蒜等"
        value="{{specialRequirements}}"
        bind:change="onSpecialRequirementsChange"
        maxlength="200"
        indicator
      />
    </view>

    <!-- 订单摘要 -->
    <view class="order-summary" wx:if="{{hasSelectedItems}}">
      <view class="order-summary-title">订单确认</view>
      <view class="summary-item {{item.type === '特殊需求' ? 'special-requirements' : ''}}" wx:for="{{orderSummary}}" wx:key="type">
        <text class="summary-label">{{item.type}}</text>
        <text class="summary-value">{{item.dishes}}</text>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <t-button
        theme="primary"
        size="large"
        block
        loading="{{submitting}}"
        bind:tap="submitOrder"
        disabled="{{!canSubmit}}"
        class="submit-button"
      >
        {{submitting ? '提交中...' : submitButtonText}}
      </t-button>
    </view>
    
  </view> <!-- 结束 menu-content -->
</view> <!-- 结束 page-container -->

<t-toast id="t-toast" />
