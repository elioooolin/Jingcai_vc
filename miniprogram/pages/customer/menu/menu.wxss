/* 页面标题 */
.page-header {
  text-align: center;
  padding: 48rpx 32rpx;
  background: var(--brand-primary);
  color: #ffffff;
  margin: -32rpx -32rpx 48rpx -32rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.95;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  color: var(--brand-primary);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid var(--brand-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--brand-primary);
  opacity: 0.8;
}

/* 菜单内容 */
.menu-content {
  min-height: calc(100vh - 200rpx);
}

/* 操作提示 */
.tips-container {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(212, 165, 116, 0.1) 0%, rgba(212, 165, 116, 0.05) 100%);
  border: 1rpx solid rgba(212, 165, 116, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 32rpx 0;
  position: relative;
}

.tips-container::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(135deg, var(--brand-primary) 0%, #e8b366 100%);
  border-radius: 3rpx 0 0 3rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  line-height: 1;
}

.tips-content {
  flex: 1;
}

.tips-text {
  font-size: 26rpx;
  color: var(--brand-text-secondary);
  line-height: 1.5;
  display: block;
}

/* 餐次区域 */
.meal-section {
  margin-bottom: 64rpx;
}

.meal-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 36rpx;
  font-weight: 500;
  color: var(--brand-primary);
}

.meal-title-icon {
  margin-right: 16rpx;
  font-size: 40rpx;
}

.meal-requirement {
  background: linear-gradient(135deg, var(--brand-bg-primary) 0%, #f5f1eb 100%);
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  border-left: 8rpx solid var(--brand-primary);
  font-weight: 500;
}

/* 子分类 */
.sub-category {
  margin-bottom: 48rpx;
}

.sub-category-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-text-secondary);
  margin-bottom: 24rpx;
}

/* 菜品网格 */
.menu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  cursor: pointer;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  position: relative;
}

.menu-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.menu-item.selected {
  border-color: var(--brand-primary);
  background: linear-gradient(135deg, rgba(212, 165, 116, 0.1), rgba(212, 165, 116, 0.05));
  box-shadow: 0 8rpx 32rpx rgba(212, 165, 116, 0.3);
}

/* 菜品图片容器 */
.dish-image-container {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 57.14%; /* 创建 7:4 的宽高比 (4/7 * 100% = 57.14%) */
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  background-color: #f8f8f8; /* 图片背景色 */
}

.dish-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background-color: #f5f5f5;
  object-fit: contain;
}

/* 图片加载失败时的占位样式 */
.dish-image-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background: linear-gradient(135deg, var(--brand-primary) 0%, #e8c4a0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
  padding: 16rpx;
  box-sizing: border-box;
}

/* 选中状态覆盖层 */
.selected-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(212, 165, 116, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
}

.selected-overlay .check-icon {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

/* 菜品名称 */
/* 菜品名称容器 */
.dish-name-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
  cursor: pointer;
  min-height: 60rpx;
}

.dish-name-container:hover {
  background-color: rgba(212, 165, 116, 0.1);
}

.dish-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.3;
  flex: 1;
  text-align: left;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8rpx;
}

/* 选择指示器 */
.select-indicator {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ddd;
  background-color: #fff;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.select-indicator.selected {
  background-color: var(--brand-primary);
  border-color: var(--brand-primary);
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.3);
}

.select-icon {
  font-size: 20rpx;
  font-weight: bold;
  color: #999;
  transition: all 0.2s ease;
}

.select-indicator.selected .select-icon {
  color: #fff;
  font-size: 18rpx;
}

/* 点击状态 */
.dish-name-container:active {
  transform: scale(0.98);
  background-color: rgba(212, 165, 116, 0.15);
}

.dish-name-container:active .select-indicator {
  transform: scale(0.95);
}

/* 隐藏旧的样式元素 */
.menu-item-icon,
.menu-item-info,
.menu-item-name,
.menu-item-desc,
.menu-item-action {
  display: none;
}

/* 订单摘要 */
.order-summary {
  background: linear-gradient(135deg, var(--brand-bg-primary) 0%, #f5f1eb 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 48rpx 0;
  border: 4rpx solid #e8c4a0;
  box-shadow: 0 8rpx 24rpx rgba(212, 165, 116, 0.1);
}

.order-summary-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
  margin-bottom: 32rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #e0e0e0;
}

.summary-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.summary-label {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  flex-shrink: 0;
  width: 120rpx;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-text);
  text-align: right;
  line-height: 1.4;
}

/* 特殊需求项的特殊样式 */
.summary-item.special-requirements {
  background: rgba(255, 243, 224, 0.8);
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  margin: 8rpx 0;
  border: 2rpx solid #f0d0a0;
}

.summary-item.special-requirements .summary-label {
  color: #d4a574;
  font-weight: 600;
}

.summary-item.special-requirements .summary-value {
  color: #8b6914;
  font-style: italic;
  text-align: left;
}

/* 提交区域 */
.submit-section {
  margin-top: 64rpx;
  margin-bottom: 32rpx;
}

.submit-button {
  --td-button-default-height: 96rpx;
  --td-button-large-font-size: 32rpx;
  --td-button-border-radius: 24rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(212, 165, 116, 0.3);
}

/* TDesign 组件样式覆盖 */
.t-textarea {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.t-textarea .t-textarea__wrapper {
  border-radius: 16rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .menu-item-icon {
    width: 80rpx;
    height: 80rpx;
    font-size: 32rpx;
    margin-right: 20rpx;
  }
  
  .menu-item-name {
    font-size: 30rpx;
  }
  
  .menu-item-desc {
    font-size: 22rpx;
  }
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  text-align: center;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.error-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--brand-text);
  margin-bottom: 16rpx;
}

.error-message {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  line-height: 1.6;
  margin-bottom: 48rpx;
  max-width: 500rpx;
}

.error-actions {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.retry-button {
  background: var(--brand-primary);
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  min-width: 160rpx;
}

.retry-button:active {
  background: #b8935a;
  transform: scale(0.98);
}

.contact-button {
  background: transparent;
  color: var(--brand-primary);
  border: 2rpx solid var(--brand-primary);
  border-radius: 24rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  min-width: 160rpx;
}

.contact-button:active {
  background: rgba(212, 165, 116, 0.1);
  transform: scale(0.98);
}
