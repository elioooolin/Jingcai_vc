/* 页面标题 */
.page-header {
  text-align: center;
  padding: 48rpx 32rpx;
  background: var(--brand-primary);
  color: #ffffff;
  margin: -32rpx -32rpx 48rpx -32rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.95;
}

/* 餐次区域 */
.meal-section {
  margin-bottom: 64rpx;
}

.meal-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 36rpx;
  font-weight: 500;
  color: var(--brand-primary);
}

.meal-title-icon {
  margin-right: 16rpx;
  font-size: 40rpx;
}

.meal-requirement {
  background: linear-gradient(135deg, var(--brand-bg-primary) 0%, #f5f1eb 100%);
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  border-left: 8rpx solid var(--brand-primary);
  font-weight: 500;
}

/* 子分类 */
.sub-category {
  margin-bottom: 48rpx;
}

.sub-category-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-text-secondary);
  margin-bottom: 24rpx;
}

/* 菜品网格 */
.menu-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-item {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 4rpx solid #f0f0f0;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  position: relative;
}

.menu-item.selected {
  border-color: var(--brand-primary);
  background: #f5f1eb;
  box-shadow: 0 4rpx 16rpx rgba(212, 165, 116, 0.15);
}

.menu-item-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 500;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-item-info {
  flex: 1;
}

.menu-item-name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
  margin-bottom: 8rpx;
}

.menu-item-desc {
  display: block;
  font-size: 24rpx;
  color: var(--brand-text-secondary);
  line-height: 1.4;
}

.menu-item-action {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background: var(--brand-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

/* 订单摘要 */
.order-summary {
  background: linear-gradient(135deg, var(--brand-bg-primary) 0%, #f5f1eb 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 48rpx 0;
  border: 4rpx solid #e8c4a0;
  box-shadow: 0 8rpx 24rpx rgba(212, 165, 116, 0.1);
}

.order-summary-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
  margin-bottom: 32rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #e0e0e0;
}

.summary-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.summary-label {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  flex-shrink: 0;
  width: 120rpx;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-text);
  text-align: right;
  line-height: 1.4;
}

/* 提交区域 */
.submit-section {
  margin-top: 64rpx;
  margin-bottom: 32rpx;
}

.submit-button {
  --td-button-default-height: 96rpx;
  --td-button-large-font-size: 32rpx;
  --td-button-border-radius: 24rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(212, 165, 116, 0.3);
}

/* TDesign 组件样式覆盖 */
.t-textarea {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.t-textarea .t-textarea__wrapper {
  border-radius: 16rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .menu-item-icon {
    width: 80rpx;
    height: 80rpx;
    font-size: 32rpx;
    margin-right: 20rpx;
  }
  
  .menu-item-name {
    font-size: 30rpx;
  }
  
  .menu-item-desc {
    font-size: 22rpx;
  }
}
