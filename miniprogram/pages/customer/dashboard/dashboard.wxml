<view class="page-container">
  <!-- 欢迎区域 -->
  <view class="welcome-section">
    <view class="welcome-card brand-gradient">
      <text class="welcome-title">您好，{{userInfo.name || '亲爱的客户'}} ✨</text>
      <text class="welcome-subtitle">{{checkInDays > 0 ? '今天是入住第' + checkInDays + '天' : '欢迎入住'}} · 爱睦陪伴您</text>
    </view>
  </view>

  <!-- 点餐内容 -->
  <view class="content-section">
        <!-- 日期选择 -->
        <view class="card">
          <view class="card-title">点击日期开始点餐</view>
          <view class="date-info">
            入住：{{userInfo.checkInDate || '2024-12-01'}} ({{userInfo.totalDays || 28}}天) | 可点餐：{{orderDateRange || '入住第8天到出所当日'}} | 需提前至少3天点餐
          </view>
          <view class="date-container">
            <view class="date-grid">
              <view 
                wx:for="{{dateList}}" 
                wx:key="date"
                class="date-item {{item.disabled || item.tooEarly || item.expired ? 'disabled' : ''}} {{item.selected ? 'selected' : ''}} {{item.isToday ? 'today' : ''}} {{item.hasOrder ? 'has-order' : ''}}"
                bind:tap="selectDate"
                data-date="{{item.date}}"
                data-index="{{index}}"
              >
                <view class="date-month" wx:if="{{item.showMonth}}">{{item.monthName}}</view>
                <view class="date-day">{{item.day}}</view>
                <view class="today-badge" wx:if="{{item.isToday}}">今天</view>
                <view class="order-badge" wx:if="{{item.hasOrder}}">已订餐</view>
              </view>
            </view>
            <view class="date-legend">
              <view class="legend-item">
                <view class="legend-dot available"></view>
                <text class="legend-text">可点餐</text>
              </view>
              <view class="legend-item">
                <view class="legend-dot disabled"></view>
                <text class="legend-text">不可点餐</text>
              </view>
              <view class="legend-item">
                <view class="legend-dot has-order"></view>
                <text class="legend-text">已订餐</text>
              </view>
              <view class="legend-item">
                <view class="legend-dot today"></view>
                <text class="legend-text">今天</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 待确定订单 -->
        <view class="pending-orders-section">
          
          <!-- 总标题 -->
          <view class="section-header" wx:if="{{pendingOrders.length > 0 || refreshingOrders}}">
            <text class="section-title">待确定订单</text>
            <view class="refresh-indicator" wx:if="{{refreshingOrders}}">
              <text class="refresh-text">正在刷新...</text>
            </view>
          </view>
          
          <!-- 订单列表 -->
          <view class="pending-orders-list" wx:if="{{pendingOrders.length > 0}}">
            <view class="pending-order-item" wx:for="{{pendingOrders}}" wx:key="uniqueKey" wx:for-index="index">
              <!-- 订单日期和状态 -->
              <view class="order-header">
                <text class="order-date-large">{{item.date}}</text>
                <view class="order-actions">
                  <t-tag 
                    theme="primary" 
                    variant="light"
                    size="small"
                  >
                    {{item.statusText}}
                  </t-tag>
                  <button 
                    class="cancel-order-btn {{cancellingOrderId === item.id ? 'cancelling' : ''}}"
                    bind:tap="cancelOrder"
                    data-order-id="{{item.id}}"
                    data-order-date="{{item.date}}"
                    disabled="{{cancellingOrderId === item.id}}"
                    wx:if="{{item.isCancelable}}"
                  >
                    {{cancellingOrderId === item.id ? '取消中...' : '取消订单'}}
                  </button>
                </view>
              </view>
              
              <!-- 订单内容 -->
              <view class="order-content">
                <view class="summary-item {{dish.type === '特殊需求' ? 'special-requirements' : ''}}" wx:for="{{item.items}}" wx:key="type" wx:for-item="dish">
                  <text class="summary-label">{{dish.type}}</text>
                  <text class="summary-value">{{dish.dishes}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 无待确定订单时的提示 -->
        <view class="card no-pending-orders" wx:if="{{pendingOrders.length === 0}}">
          <view class="empty-state">
            <text class="empty-icon">📋</text>
            <text class="empty-title">暂无待确定订单</text>
            <text class="empty-desc">您当前没有需要确认的订单</text>
          </view>
        </view>
  </view>
</view>

<t-toast id="t-toast" />
