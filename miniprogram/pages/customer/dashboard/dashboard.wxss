/* 欢迎区域 */
.welcome-section {
  margin-bottom: 32rpx;
}

.welcome-card {
  padding: 48rpx 32rpx;
  border-radius: 32rpx;
  text-align: center;
  color: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(212, 165, 116, 0.25);
}

.welcome-title {
  display: block;
  font-size: 40rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.welcome-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.95;
  font-weight: 300;
  letter-spacing: 1rpx;
}

/* 内容区域 */
.content-section {
  margin-bottom: 32rpx;
}

/* 日期选择器 */
.date-info {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

/* 小屏幕日期信息优化 */
@media (max-width: 400px) {
  .date-info {
    font-size: 20rpx;
    margin-bottom: 20rpx;
  }
}

@media (max-width: 350px) {
  .date-info {
    font-size: 18rpx;
    margin-bottom: 16rpx;
  }
}

.date-container {
  margin-top: 24rpx;
}

.date-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
  margin-bottom: 32rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 0 2rpx;
}

.date-item {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 20rpx;
  transition: all 0.3s ease;
  cursor: pointer;
  padding: 4rpx 2rpx;
  position: relative;
  min-height: 80rpx;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.date-item:hover:not(.disabled) {
  background: var(--brand-primary-dark);
  border-color: var(--brand-primary);
  transform: translateY(-2rpx);
}

.date-item.selected {
  background: var(--brand-primary);
  color: #ffffff;
  border-color: var(--brand-primary);
  box-shadow: 0 6rpx 20rpx rgba(212, 165, 116, 0.3);
  transform: translateY(-4rpx);
}

.date-item.selected .date-day {
  color: #ffffff;
  font-weight: 700;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.date-item.disabled {
  opacity: 0.4;
  cursor: not-allowed;
  background: #f5f5f5;
  color: #999;
  border-color: #e0e0e0;
}

.date-item.today:not(.selected):not(.disabled) {
  border-color: var(--brand-primary);
  border-width: 3rpx;
}

.date-month {
  font-size: 16rpx;
  color: var(--brand-primary);
  font-weight: 600;
  margin-bottom: 2rpx;
  line-height: 1;
}

.date-item.selected .date-month {
  color: rgba(255, 255, 255, 0.9);
}

.date-day {
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 2rpx;
  line-height: 1;
}

.today-badge {
  font-size: 12rpx;
  color: var(--brand-primary);
  font-weight: 500;
  margin-top: 2rpx;
  background: rgba(212, 165, 116, 0.1);
  padding: 1rpx 6rpx;
  border-radius: 8rpx;
  line-height: 1.2;
}

.date-item.selected .today-badge {
  background: rgba(255, 255, 255, 0.2);
  color: white;
}

/* 已订餐日期样式 */
.date-item.has-order {
  background: linear-gradient(135deg, #e8f5e8 0%, #d4f4d4 100%);
  border-color: #4caf50;
  border-width: 2rpx;
  position: relative;
}

.date-item.has-order .date-day {
  color: #2e7d32;
}

.date-item.has-order .date-month {
  color: #4caf50;
}

.order-badge {
  font-size: 12rpx;
  color: #2e7d32;
  font-weight: 500;
  margin-top: 2rpx;
  background: rgba(76, 175, 80, 0.15);
  padding: 1rpx 6rpx;
  border-radius: 8rpx;
  line-height: 1.2;
}

/* 响应式设计 - 小屏幕适配 */
@media (max-width: 400px) {
  .date-grid {
    gap: 2rpx;
    padding: 0 1rpx;
  }
  
  .date-item {
    min-height: 70rpx;
    padding: 3rpx 1rpx;
    border-radius: 8rpx;
  }
  
  .date-month {
    font-size: 14rpx;
    margin-bottom: 1rpx;
  }
  
  .date-day {
    font-size: 18rpx;
  }
  
  .today-badge {
    font-size: 10rpx;
    padding: 1rpx 4rpx;
    margin-top: 1rpx;
  }
}

/* 超小屏幕适配 */
@media (max-width: 350px) {
  .date-grid {
    gap: 1rpx;
    padding: 0;
  }
  
  .date-item {
    min-height: 60rpx;
    padding: 2rpx 1rpx;
    border-radius: 6rpx;
    border-width: 1rpx;
  }
  
  .date-month {
    font-size: 12rpx;
  }
  
  .date-day {
    font-size: 16rpx;
  }
  
  .today-badge {
    font-size: 9rpx;
    padding: 1rpx 3rpx;
  }
}

/* 日期图例 */
.date-legend {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 32rpx;
  padding: 24rpx 0;
  border-top: 2rpx solid #f0f0f0;
  margin-top: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid;
}

.legend-dot.available {
  background: var(--brand-primary);
  border-color: var(--brand-primary);
}

.legend-dot.disabled {
  background: #f5f5f5;
  border-color: #e0e0e0;
}

.legend-dot.today {
  background: transparent;
  border-color: var(--brand-primary);
  border-width: 3rpx;
}

.legend-dot.has-order {
  background: linear-gradient(135deg, #e8f5e8 0%, #d4f4d4 100%);
  border-color: #4caf50;
  border-width: 2rpx;
}

.legend-text {
  font-size: 24rpx;
  color: #666;
}

/* 待确定订单区域样式 */
.section-header {
  margin-bottom: 24rpx;
  padding: 0 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--brand-text);
}

.refresh-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.refresh-text {
  font-size: 24rpx;
  color: var(--brand-primary);
  opacity: 0.8;
}

.pending-orders-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.pending-order-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 0 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #f0f0f0;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.order-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cancel-order-btn {
  background: #fff;
  border: 2rpx solid #ff6b6b;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #ff6b6b;
  line-height: 1;
  min-width: auto;
  height: auto;
}

.cancel-order-btn::after {
  border: none;
}

.cancel-order-btn:active {
  background: #fff5f5;
  transform: scale(0.98);
}

.cancel-order-btn.cancelling,
.cancel-order-btn[disabled] {
  background: #f5f5f5;
  border-color: #d9d9d9;
  color: #999;
  opacity: 0.6;
}

.cancel-order-btn.cancelling:active,
.cancel-order-btn[disabled]:active {
  transform: none;
  background: #f5f5f5;
}

.order-date-large {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--brand-primary);
  letter-spacing: 0.5rpx;
}

.order-content {
  margin-top: 0;
}

.order-content .summary-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.order-content .summary-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

/* 空状态样式 */
.no-pending-orders {
  text-align: center;
  padding: 60rpx 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.6;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  line-height: 1.5;
}


/* 订单项目 */
.order-items {
  margin-top: 24rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.summary-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.summary-label {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  min-width: 120rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-text);
  flex: 1;
  margin-left: 16rpx;
  text-align: right;
  word-wrap: break-word;
  line-height: 1.4;
}

/* 特殊需求项的特殊样式 */
.summary-item.special-requirements {
  background: rgba(255, 243, 224, 0.8);
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  margin: 8rpx 0;
  border: 2rpx solid #f0d0a0;
}

.summary-item.special-requirements .summary-label {
  color: #d4a574;
  font-weight: 600;
}

.summary-item.special-requirements .summary-value {
  color: #8b6914;
  font-style: italic;
  text-align: left;
}



.t-cell-group {
  border-radius: 24rpx;
  overflow: hidden;
}

.t-cell {
  background: #ffffff;
}

.t-tag--primary.t-tag--variant-light {
  background-color: #e6f2ff;
  color: #1a5490;
  border-color: #9cc5f0;
}

.t-tag--success.t-tag--variant-light {
  background-color: #e8f5e8;
  color: #2d5a2d;
  border-color: #a5c9a5;
}
