<view class="page-container">
  <!-- 订单历史列表 -->
  <view class="order-history-section">
    <!-- 空状态 -->
    <view wx:if="{{orderList.length === 0 && !loading}}" class="empty-state">
      <view class="empty-icon">📋</view>
      <text class="empty-text">暂无订单记录</text>
      <text class="empty-desc">您还没有提交过订单</text>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <text class="loading-text">正在加载订单历史...</text>
    </view>

    <!-- 订单列表 -->
    <view class="order-history-list" wx:if="{{orderList.length > 0}}">
      <view class="history-order-item" wx:for="{{orderList}}" wx:key="id" wx:for-index="index">
        <!-- 订单日期和状态 -->
        <view class="order-header">
          <text class="order-date-large">{{item.date}}</text>
          <view class="order-status">
            <t-tag 
              theme="{{item.statusText === '已上餐' ? 'success' : item.statusText === '已确认' ? 'primary' : 'warning'}}" 
              variant="light"
              size="small"
            >
              {{item.statusText}}
            </t-tag>
          </view>
        </view>
        
        <!-- 提交时间 -->
        <view class="submit-time">
          <text class="submit-time-text">提交时间：{{item.submitTime}}</text>
        </view>
        
        <!-- 订单内容 -->
        <view class="order-content">
          <view class="summary-item {{dish.type === '特殊需求' ? 'special-requirements' : ''}}" wx:for="{{item.items}}" wx:key="type" wx:for-item="dish">
            <text class="summary-label">{{dish.type}}</text>
            <text class="summary-value">{{dish.dishes}}</text>
          </view>
          
          <!-- 特殊需求 -->
          <view wx:if="{{item.specialRequirements}}" class="summary-item special-requirements">
            <text class="summary-label">特殊需求</text>
            <text class="summary-value">{{item.specialRequirements}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 使用原生 API，不需要这些组件 -->
