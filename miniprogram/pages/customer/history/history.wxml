<view class="page-container">
  <!-- 筛选区域 -->
  <view class="filter-section">
    <t-card title="筛选条件">
      <view class="filter-row">
        <t-picker
          title="选择月份"
          value="{{selectedMonth}}"
          data-source="{{monthOptions}}"
          bind:change="onMonthChange"
        >
          <t-cell title="月份" note="{{selectedMonthText}}" arrow />
        </t-picker>
      </view>
      
      <view class="filter-row">
        <t-picker
          title="订单状态"
          value="{{selectedStatus}}"
          data-source="{{statusOptions}}"
          bind:change="onStatusChange"
        >
          <t-cell title="状态" note="{{selectedStatusText}}" arrow />
        </t-picker>
      </view>
    </t-card>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view wx:if="{{orderList.length === 0}}" class="empty-state">
      <view class="empty-icon">📋</view>
      <text class="empty-text">暂无订单记录</text>
      <text class="empty-desc">您还没有提交过订单</text>
    </view>

    <t-card 
      wx:for="{{orderList}}" 
      wx:key="id"
      class="order-card"
    >
      <view slot="header" class="order-header">
        <view class="order-date-info">
          <text class="order-date">{{item.date}}</text>
          <text class="order-time">提交时间：{{item.submitTime}}</text>
        </view>
        <t-tag 
          theme="{{item.status === 'confirmed' ? 'success' : item.status === 'submitted' ? 'primary' : 'warning'}}"
          variant="light"
          size="small"
        >
          {{item.statusText}}
        </t-tag>
      </view>

      <view class="order-content">
        <!-- 菜品列表 -->
        <view class="dishes-section">
          <view 
            wx:for="{{item.dishes}}" 
            wx:key="type"
            wx:for-item="dish"
            class="dish-item"
          >
            <text class="dish-type">{{dish.type}}</text>
            <text class="dish-names">{{dish.names}}</text>
          </view>
        </view>

        <!-- 特殊需求 -->
        <view wx:if="{{item.specialRequirements}}" class="special-requirements">
          <text class="special-label">特殊需求：</text>
          <text class="special-content">{{item.specialRequirements}}</text>
        </view>

        <!-- 操作按钮 -->
        <view class="order-actions" wx:if="{{item.status === 'submitted'}}">
          <t-button 
            theme="light" 
            size="small"
            bind:tap="editOrder"
            data-id="{{item.id}}"
          >
            修改订单
          </t-button>
          <t-button 
            theme="light" 
            size="small"
            bind:tap="cancelOrder"
            data-id="{{item.id}}"
          >
            取消订单
          </t-button>
        </view>
      </view>
    </t-card>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <t-button 
      theme="light" 
      size="small"
      loading="{{loadingMore}}"
      bind:tap="loadMore"
    >
      {{loadingMore ? '加载中...' : '加载更多'}}
    </t-button>
  </view>
</view>

<t-toast id="t-toast" />
<t-dialog id="t-dialog" />
