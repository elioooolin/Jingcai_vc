/* 页面容器 */
.page-container {
  padding: 32rpx;
  background: #faf8f5;
  min-height: 100vh;
}

/* 订单历史区域 */
.order-history-section {
  margin-bottom: 32rpx;
}

/* 订单历史列表 */
.order-history-list {
  margin-bottom: 32rpx;
}

.history-order-item {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 20rpx -4rpx rgba(0, 0, 0, 0.12), 0 2rpx 6rpx -4rpx rgba(0, 0, 0, 0.08);
}

.history-order-item:last-child {
  margin-bottom: 0;
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-date-large {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--brand-text);
}

.order-status {
  flex-shrink: 0;
}

/* 提交时间 */
.submit-time {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.submit-time-text {
  font-size: 26rpx;
  color: var(--brand-text-secondary);
}

/* 订单内容 */
.order-content {
  /* 无需额外padding，已在submit-time中处理 */
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.summary-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.summary-label {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  min-width: 120rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-text);
  flex: 1;
  margin-left: 16rpx;
  text-align: right;
  word-wrap: break-word;
  line-height: 1.4;
}

.summary-item.special-requirements .summary-label,
.summary-item.special-requirements .summary-value {
  color: #d4a574;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 128rpx 64rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 128rpx 64rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: var(--brand-text);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-desc {
  display: block;
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  line-height: 1.4;
}
