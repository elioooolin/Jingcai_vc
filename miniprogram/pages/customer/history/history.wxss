/* 筛选区域 */
.filter-section {
  margin-bottom: 32rpx;
}

.filter-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 20rpx -4rpx rgba(0, 0, 0, 0.12), 0 2rpx 6rpx -4rpx rgba(0, 0, 0, 0.08);
}

.filter-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.filter-row {
  margin-bottom: 16rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

/* 订单列表 */
.order-list {
  margin-bottom: 32rpx;
}

.order-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 20rpx -4rpx rgba(0, 0, 0, 0.12), 0 2rpx 6rpx -4rpx rgba(0, 0, 0, 0.08);
}

.order-card:last-child {
  margin-bottom: 0;
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.order-date-info {
  flex: 1;
}

.order-date {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
  margin-bottom: 8rpx;
}

.order-time {
  display: block;
  font-size: 24rpx;
  color: var(--brand-text-secondary);
}

/* 订单内容 */
.order-content {
  padding-top: 24rpx;
}

.dishes-section {
  margin-bottom: 24rpx;
}

.dish-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.dish-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.dish-type {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  flex-shrink: 0;
  width: 120rpx;
}

.dish-names {
  font-size: 28rpx;
  color: var(--brand-text);
  font-weight: 500;
  text-align: right;
  line-height: 1.4;
}

/* 特殊需求 */
.special-requirements {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid var(--brand-primary);
}

.special-label {
  font-size: 26rpx;
  color: var(--brand-text-secondary);
  font-weight: 500;
}

.special-content {
  font-size: 26rpx;
  color: var(--brand-text);
  line-height: 1.4;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 128rpx 64rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: var(--brand-text);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-desc {
  display: block;
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  line-height: 1.4;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx 0;
}

/* TDesign 组件样式覆盖 */
.t-card {
  border-radius: 24rpx;
  box-shadow: 0 2rpx 20rpx -4rpx rgba(0, 0, 0, 0.12);
}

.t-card__header {
  padding: 32rpx 32rpx 0 32rpx;
}

.t-card__body {
  padding: 0 32rpx 32rpx 32rpx;
}

.t-tag--success.t-tag--variant-light {
  background-color: #e8f5e8;
  color: #2d5a2d;
  border-color: #a5c9a5;
}

.t-tag--primary.t-tag--variant-light {
  background-color: #e6f2ff;
  color: #1a5490;
  border-color: #9cc5f0;
}

.t-tag--warning.t-tag--variant-light {
  background-color: #fef4e8;
  color: #a67c52;
  border-color: #e8c4a0;
}
