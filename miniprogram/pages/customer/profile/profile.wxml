<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="profile-header">
    <view class="user-info-section">
      <text class="user-name">{{isVisitor ? '' : (userInfo.name || '用户')}}</text>
      <text class="user-desc">{{isVisitor ? '' : '欢迎入住·爱睦 Love Moon'}}</text>
    </view>
  </view>

  <!-- 个人信息 -->
  <t-card title="个人信息" class="info-card">
    <t-cell-group>
      <t-cell 
        title="姓名" 
        note="{{isVisitor ? '' : (userInfo.name && userInfo.name !== 'undefined' ? userInfo.name : '未设置')}}"
      />
      <t-cell 
        title="手机号" 
        note="{{isVisitor ? '' : userInfo.phone}}"
      />
      <t-cell 
        title="生日" 
        note="{{isVisitor ? '' : userInfo.birthday}}"
      />
      <t-cell 
        title="入住门店" 
        note="{{isVisitor ? '' : (userInfo.store && userInfo.store !== 'undefined' ? userInfo.store : '未设置')}}"
      />
      <t-cell 
        title="房间号" 
        note="{{isVisitor ? '' : (userInfo.room && userInfo.room !== 'undefined' ? userInfo.room : '未设置')}}"
      />
      <t-cell 
        title="入住日期" 
        note="{{isVisitor ? '' : userInfo.checkInDate}}"
      />
      <t-cell 
        title="入住天数" 
        note="{{isVisitor ? '' : (userInfo.totalDays && userInfo.totalDays !== 'undefined' ? userInfo.totalDays + '天' : '未设置')}}"
      />
    </t-cell-group>
  </t-card>

  <!-- 饮食偏好 -->
  <t-card title="饮食偏好" class="preference-card">
    <t-cell-group>
      <t-cell 
        title="饮食偏好" 
        note="{{isVisitor ? '' : (userInfo.dietPreference && userInfo.dietPreference !== 'undefined' ? userInfo.dietPreference : '无特殊偏好')}}"
      />
      <t-cell 
        title="剩余高补餐次数" 
        note="{{isVisitor ? '' : userInfo.supplementCount}}"
      />
      <t-cell 
        title="赠送陪人餐次数" 
        note="{{isVisitor ? '' : userInfo.freeFamilyMealCount}}"
      />
    </t-cell-group>
  </t-card>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <t-button
      theme="light"
      size="large"
      block
      bind:tap="logout"
      class="logout-btn"
    >
      退出登录
    </t-button>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <text class="loading-text">正在加载用户信息...</text>
  </view>
</view>
