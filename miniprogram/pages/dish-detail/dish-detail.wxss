/* 菜品头部 */
.dish-header {
  background: #ffffff;
  padding: 48rpx 32rpx;
  margin: -32rpx -32rpx 32rpx -32rpx;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.dish-image-container {
  width: 100%;
  max-width: 560rpx;
  margin: 0 auto 32rpx;
  position: relative;
  height: 0;
  padding-bottom: 57.14%; /* 7:4 宽高比 (4/7 * 100% = 57.14%) */
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(212, 165, 116, 0.25);
}

.dish-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
  background-color: #f8f8f8;
  object-fit: cover;
}

/* 图片占位符样式 */
.dish-image-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d1d5db;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.placeholder-text {
  font-size: 24rpx;
  color: #6b7280;
  opacity: 0.8;
}


.dish-basic-info {
  text-align: center;
  padding: 32rpx 32rpx 0;
}

.dish-name {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: var(--brand-text);
  margin-bottom: 24rpx;
  line-height: 1.3;
}

/* 信息区域样式 */
.info-section {
  margin: 24rpx 0;
  text-align: left;
}

.info-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--brand-text);
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.info-label::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(135deg, var(--brand-primary) 0%, #e8b366 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.info-content {
  font-size: 26rpx;
  color: var(--brand-text-secondary);
  line-height: 1.5;
  padding-left: 18rpx;
}

/* 关键词容器 */
.keywords-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-left: 18rpx;
}

.keyword-tag {
  margin: 0;
  background: transparent !important;
  border: none !important;
  color: var(--brand-text-secondary) !important;
  font-size: 26rpx !important;
  padding: 0 !important;
  font-weight: normal !important;
}

/* 主厨推荐标识优化 */
.chef-recommend-badge {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin: 16rpx 0 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.chef-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.chef-text {
  font-size: 24rpx;
}

.dish-description {
  display: block;
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  line-height: 1.6;
  text-align: justify;
  margin: 32rpx 0;
  padding: 24rpx;
  background: rgba(212, 165, 116, 0.05);
  border-radius: 16rpx;
  border-left: 6rpx solid var(--brand-primary);
}

/* 营养成分 */
.nutrition-card {
  margin-bottom: 32rpx;
}

.nutrition-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.nutrition-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--brand-text);
  margin-bottom: 8rpx;
}

.nutrition-subtitle {
  font-size: 24rpx;
  color: var(--brand-text-secondary);
  opacity: 0.8;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx 48rpx;
  padding: 32rpx 16rpx;
}

.nutrition-item {
  text-align: center;
  padding: 16rpx;
  background: rgba(212, 165, 116, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(212, 165, 116, 0.1);
}

.nutrition-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--brand-primary);
  margin-bottom: 8rpx;
}

.nutrition-name {
  display: block;
  font-size: 24rpx;
  color: var(--brand-text-secondary);
  font-weight: 500;
}



/* TDesign 组件样式覆盖 */
.t-card {
  border-radius: 24rpx;
  box-shadow: 0 2rpx 20rpx -4rpx rgba(0, 0, 0, 0.12);
}

.t-card__header {
  padding: 32rpx 32rpx 16rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.t-card__body {
  padding: 16rpx 32rpx 32rpx 32rpx;
}

.t-card__title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
  display: flex;
  align-items: center;
}

.t-card__title::before {
  content: '📊';
  margin-right: 12rpx;
  font-size: 28rpx;
}


.t-cell-group {
  border-radius: 0;
  overflow: hidden;
}

.t-cell {
  background: #ffffff;
  padding: 24rpx 0;
}

.t-cell__title {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  flex-shrink: 0;
  width: 160rpx;
}

.t-cell__note {
  font-size: 28rpx;
  color: var(--brand-text);
  font-weight: 500;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .dish-name {
    font-size: 42rpx;
  }
  
  .nutrition-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24rpx;
  }
  
}
