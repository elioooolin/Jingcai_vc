<view class="page-container">
  <!-- 菜品图片和基本信息 -->
  <view class="dish-header">
    <view class="dish-image-container">
      <image 
        class="dish-image" 
        src="{{dishInfo.imageUrl}}" 
        mode="aspectFill"
        data-url="{{dishInfo.imageUrl}}"
        bind:error="onImageError"
        lazy-load="{{true}}"
      />
    </view>
    
    <view class="dish-basic-info">
      <text class="dish-name">{{dishInfo.name}}</text>
      
      <!-- 主厨推荐标识 -->
      <view class="chef-recommend-badge" wx:if="{{dishInfo.chefRecommend}}">
        <text class="chef-icon">👨‍🍳</text>
        <text class="chef-text">主厨推荐</text>
      </view>
      
      <!-- 主要食材 -->
      <view class="info-section">
        <view class="info-label">主要食材</view>
        <text class="info-content">{{dishInfo.ingredients || '优质食材精选'}}</text>
      </view>
      
      <!-- 特点标签 -->
      <view class="info-section" wx:if="{{dishInfo.keywords && dishInfo.keywords.length > 0}}">
        <view class="info-label">特点</view>
        <view class="keywords-container">
          <t-tag 
            wx:for="{{dishInfo.keywords}}" 
            wx:key="*this"
            theme="primary" 
            variant="light"
            size="small"
            class="keyword-tag"
          >
            {{item}}
          </t-tag>
        </view>
      </view>
      
      <text class="dish-description">{{dishInfo.description}}</text>
    </view>
  </view>

  <!-- 营养成分 -->
  <t-card class="nutrition-card">
    <view slot="header" class="nutrition-header">
      <text class="nutrition-title">营养成分</text>
      <text class="nutrition-subtitle">每100g含量</text>
    </view>
    <view class="nutrition-grid">
      <view class="nutrition-item">
        <text class="nutrition-value">{{dishInfo.nutritional_info.calories || '--'}}</text>
        <text class="nutrition-name">热量(kcal)</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{dishInfo.nutritional_info.protein || '--'}}</text>
        <text class="nutrition-name">蛋白质(g)</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{dishInfo.nutritional_info.fat || '--'}}</text>
        <text class="nutrition-name">脂肪(g)</text>
      </view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{dishInfo.nutritional_info.carbohydrates || '--'}}</text>
        <text class="nutrition-name">碳水化合物(g)</text>
      </view>
    </view>
  </t-card>

</view>

<t-toast id="t-toast" />
