<view class="page-container">
  <!-- 页面标题 -->
  <view class="page-header admin-gradient">
    <text class="page-title">{{isEdit ? '编辑客户' : '添加新客户'}}</text>
    <text class="page-subtitle">{{customerManageSubtitle}}</text>
  </view>

  <!-- 表单内容 -->
  <view class="form-container">
    <!-- 基本信息 -->
    <view class="form-section">
      <view class="section-title">基本信息</view>
      
      <view class="form-group">
        <t-input
          label="客户姓名"
          placeholder="请输入客户姓名"
          value="{{formData.name}}"
          bind:change="onFieldChange"
          data-field="name"
          required
        />
      </view>
      
      <view class="form-group">
        <t-input
          label="手机号码"
          type="number"
          placeholder="请输入手机号"
          value="{{formData.phone}}"
          bind:change="onFieldChange"
          data-field="phone"
          maxlength="11"
          required
        />
      </view>
      
      <view class="form-group">
        <t-cell 
          title="生日" 
          note="{{formData.birthday || '请选择生日'}}" 
          arrow 
          required 
          data-field="birthday"
          bind:click="showDatePicker"
        />
        <t-date-time-picker
          title="选择生日"
          visible="{{birthdayVisible}}"
          mode="date"
          value="{{formData.birthday}}"
          bind:change="onBirthdayConfirm"
          bind:pick="onBirthdayPick"
          bind:cancel="hideDatePicker"
          start="{{birthdayStart}}"
          end="{{birthdayEnd}}"
        />
      </view>
    </view>

    <!-- 入住信息 -->
    <view class="form-section">
      <view class="section-title">入住信息</view>
      
      <view class="form-group">
        <t-cell 
          title="入住日期" 
          note="{{formData.checkInDate || '请选择入住日期'}}" 
          arrow 
          required 
          data-field="checkInDate"
          bind:click="showDatePicker"
        />
        <t-date-time-picker
          title="选择入住日期"
          visible="{{checkInDateVisible}}"
          mode="date"
          value="{{formData.checkInDate}}"
          bind:change="onCheckInDateConfirm"
          bind:pick="onCheckInDatePick"
          bind:cancel="hideDatePicker"
          start="2025-09-01"
          end="2030-12-31"
        />
      </view>
      
      <view class="form-group">
        <t-input
          label="入住天数"
          type="number"
          placeholder="请输入入住天数"
          value="{{formData.totalDays}}"
          bind:change="onFieldChange"
          data-field="totalDays"
          required
        />
      </view>
      
      <view class="form-group">
        <t-cell 
          title="入住门店" 
          note="{{storeText}}" 
          arrow 
          required 
          data-field="store"
          bind:click="showPicker"
        />
        <t-picker
          title="选择门店"
          visible="{{storeVisible}}"
          value="{{[formData.store]}}"
          cancelBtn="取消"
          confirmBtn="确认"
          bind:change="onStoreConfirm"
          bind:pick="onStorePick"
          bind:cancel="hidePicker"
        >
          <t-picker-item options="{{storeOptions}}" />
        </t-picker>
      </view>
      
      <view class="form-group">
        <t-input
          label="房间号码"
          placeholder="请输入房间号，如：201"
          value="{{formData.room}}"
          bind:change="onFieldChange"
          data-field="room"
          required
        />
      </view>
    </view>

    <!-- 餐食信息 -->
    <view class="form-section">
      <view class="section-title">餐食信息</view>
      
      <view class="form-group">
        <t-textarea
          label="饮食偏好"
          placeholder="请描述客户的饮食偏好，如不吃辣、素食、过敏食物等（选填）"
          value="{{formData.dietPreference}}"
          bind:change="onFieldChange"
          data-field="dietPreference"
          maxlength="200"
          indicator
        />
      </view>
      
      <view class="form-group">
        <t-input
          label="高补餐次数"
          type="number"
          placeholder="请输入高补餐次数（0-20）"
          value="{{formData.supplementCount}}"
          bind:change="onFieldChange"
          data-field="supplementCount"
          required
        />
      </view>

      <view class="form-group">
        <t-input
          label="陪人餐次数"
          type="number"
          placeholder="请输入陪人餐次数（0-999）"
          value="{{formData.freeFamilyMealCount}}"
          bind:change="onFieldChange"
          data-field="freeFamilyMealCount"
          required
        />
      </view>
    </view>


    <!-- 操作按钮 -->
    <view class="action-buttons">
      <t-button
        theme="primary"
        size="large"
        block
        loading="{{submitting}}"
        bind:tap="submitForm"
        class="admin-button"
      >
        {{submitting ? (isEdit ? '保存中...' : '添加中...') : (isEdit ? '保存修改' : '添加客户')}}
      </t-button>
      
      <t-button
        theme="light"
        size="large"
        block
        bind:tap="goBack"
        class="cancel-button"
      >
        取消
      </t-button>
    </view>

    <!-- 提示信息 -->
    <view class="tip-section">
      <view class="tip-card">
        <text class="tip-title">💡 添加客户须知</text>
        <view class="tip-content">
          <text class="tip-item">• 手机号将作为客户登录的唯一标识</text>
          <text class="tip-item">• 请确保手机号填写正确，客户将通过此号码登录</text>
          <text class="tip-item">• 标有必填的字段必须填写</text>
          <text class="tip-item">• 添加成功后，客户即可使用手机号快捷登录系统</text>
        </view>
      </view>
    </view>
  </view>
</view>

<t-toast id="t-toast" />
