/* 页面标题 */
.page-header {
  text-align: center;
  padding: 48rpx 32rpx;
  color: #ffffff;
  margin: -32rpx -32rpx 48rpx -32rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.95;
}

/* 表单容器 */
.form-container {
  padding-bottom: 32rpx;
}

.form-section {
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

/* 操作按钮 */
.action-buttons {
  margin: 64rpx 0 48rpx 0;
}

/* 管理员按钮样式 */
.admin-button {
  --td-button-primary-bg-color: var(--admin-primary);
  --td-button-primary-border-color: var(--admin-primary);
  --td-button-default-height: 96rpx;
  --td-button-large-font-size: 32rpx;
  --td-button-border-radius: 24rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(139, 157, 195, 0.3);
}

.admin-button:not(.t-is-disabled):active {
  --td-button-primary-active-bg-color: #7a8bb5;
  --td-button-primary-active-border-color: #7a8bb5;
}

/* 提示信息 */
.tip-section {
  margin-top: 32rpx;
}

.tip-card {
  background: #e6f2ff;
  border: 2rpx solid #9cc5f0;
  border-radius: 24rpx;
  padding: 32rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a5490;
  margin-bottom: 24rpx;
}

.tip-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #1a5490;
  line-height: 1.5;
}

/* TDesign 组件样式覆盖 */
.t-card {
  border-radius: 24rpx;
  box-shadow: 0 2rpx 20rpx -4rpx rgba(0, 0, 0, 0.12);
}

.t-card__header {
  padding: 32rpx 32rpx 16rpx 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.t-card__body {
  padding: 16rpx 32rpx 32rpx 32rpx;
}

.t-card__title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
}

.t-input {
  margin-bottom: 0;
}

.t-input__label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-text);
}

.t-input__control {
  border-radius: 16rpx;
  border: 2rpx solid #e5e7eb;
  font-size: 32rpx;
}

.t-input__control:focus-within {
  border-color: var(--admin-primary);
  box-shadow: 0 0 0 6rpx rgba(139, 157, 195, 0.1);
}

.t-textarea {
  margin-bottom: 0;
}

.t-textarea__label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--brand-text);
}

.t-textarea__wrapper {
  border-radius: 16rpx;
  border: 2rpx solid #e5e7eb;
}

.t-textarea__wrapper:focus-within {
  border-color: var(--admin-primary);
  box-shadow: 0 0 0 6rpx rgba(139, 157, 195, 0.1);
}

.t-cell {
  background: #ffffff;
  padding: 24rpx 0;
}

.t-cell__title {
  font-size: 28rpx;
  color: var(--brand-text);
  font-weight: 500;
}

.t-cell__note {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
}

.t-cell--clickable:active {
  background-color: #f5f5f5;
}

/* 必填字段标识 */
.t-cell[required]::after,
.t-input[required] .t-input__label::after,
.t-textarea[required] .t-textarea__label::after {
  content: ' *';
  color: #ef4444;
  font-weight: 500;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .page-title {
    font-size: 32rpx;
  }
  
  .page-subtitle {
    font-size: 26rpx;
  }
  
  .form-group {
    margin-bottom: 28rpx;
  }
  
  .tip-title {
    font-size: 26rpx;
  }
  
  .tip-item {
    font-size: 24rpx;
  }
}
