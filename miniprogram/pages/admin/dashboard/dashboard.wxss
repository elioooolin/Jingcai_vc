/* 管理员头部 */
.admin-header {
  margin-bottom: 32rpx;
}

.admin-welcome {
  padding: 48rpx 32rpx;
  border-radius: 32rpx;
  text-align: center;
  color: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(139, 157, 195, 0.25);
}

.welcome-title {
  display: block;
  font-size: 40rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.welcome-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.95;
  font-weight: 300;
  letter-spacing: 1rpx;
}

/* 统计数据 */
.stats-section {
  margin-bottom: 32rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 20rpx -4rpx rgba(0, 0, 0, 0.12);
}

.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: var(--admin-primary);
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--brand-text-secondary);
}

/* 标签页区域 */
.tabs-section {
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
  background: transparent;
}

/* 筛选器区域 */
.filter-section {
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx -4rpx rgba(0, 0, 0, 0.08);
}

/* 确保tabs组件可见 */
.tabs-section t-tabs {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}


/* 通用卡片样式 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 20rpx -4rpx rgba(0, 0, 0, 0.12);
  margin-bottom: 32rpx;
  overflow: hidden;
}

.card-header {
  padding: 32rpx 32rpx 0 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
  display: block;
  padding-bottom: 24rpx;
}

.card-body {
  padding: 32rpx;
}

/* 日期卡片 */
.date-card {
  margin-bottom: 32rpx;
}

/* 自定义日历样式 */
.date-card t-calendar {
  --td-calendar-header-bg-color: var(--admin-primary);
  --td-calendar-header-color: #ffffff;
  --td-calendar-selected-bg-color: var(--admin-primary);
  --td-calendar-selected-color: #ffffff;
}

/* 订单列表 */
.order-list {
  margin-bottom: 32rpx;
}

.order-item-card {
  margin-bottom: 24rpx;
}

.order-item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.customer-info {
  flex: 1;
}

.customer-name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
  margin-bottom: 8rpx;
}

.submit-time {
  display: block;
  font-size: 24rpx;
  color: var(--brand-text-secondary);
}

/* 订单内容 */
.order-content {
  padding-top: 24rpx;
}

/* 订单摘要 */
.order-summary {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border-left: 6rpx solid var(--admin-primary);
}

.summary-text {
  font-size: 28rpx;
  color: var(--brand-text);
  line-height: 1.5;
  word-wrap: break-word;
}

/* 特殊需求 */
.special-note {
  background: #fff7e6;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #fbbf24;
}

.special-label {
  font-size: 26rpx;
  color: #a67c52;
  font-weight: 500;
}

.special-content {
  font-size: 26rpx;
  color: #a67c52;
  line-height: 1.4;
}

/* 订单操作 */
.order-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

/* 客户管理 */
.add-customer-btn {
  margin-bottom: 32rpx;
}

.customer-list {
  margin-bottom: 32rpx;
}

.customer-item-card {
  margin-bottom: 24rpx;
}

.customer-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.customer-main-info {
  flex: 1;
}

.customer-name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--brand-text);
  margin-bottom: 8rpx;
}

.customer-details {
  display: block;
  font-size: 24rpx;
  color: var(--brand-text-secondary);
  margin-bottom: 4rpx;
}

.customer-checkin {
  display: block;
  font-size: 24rpx;
  color: var(--brand-text-secondary);
}

.customer-actions {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.delete-customer-btn {
  background-color: #ff4757 !important;
  border-color: #ff4757 !important;
  color: white !important;
}

/* 数据导出 */
.export-card {
  margin-bottom: 32rpx;
}

.export-actions {
  margin-bottom: 32rpx;
}

.export-preview {
  margin-bottom: 32rpx;
}

.preview-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.preview-item {
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  line-height: 1.4;
}

.portal-card {
  margin-bottom: 32rpx;
}

.portal-desc {
  display: block;
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  line-height: 1.7;
  margin-bottom: 28rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 128rpx 64rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: var(--brand-text);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-desc {
  display: block;
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  line-height: 1.4;
}

/* 个人中心样式 */
.admin-info-card,
.system-functions-card,
.system-stats-card {
  margin-bottom: 32rpx;
}

.stats-grid-mini {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 24rpx;
}

.stat-item-mini {
  text-align: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.stat-number-mini {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--admin-primary);
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.stat-label-mini {
  display: block;
  font-size: 22rpx;
  color: var(--brand-text-secondary);
}

.profile-actions {
  margin-top: 48rpx;
  margin-bottom: 32rpx;
}

.mb-24 {
  margin-bottom: 24rpx;
}

/* 退出登录区域 */
.logout-section {
  margin-top: 48rpx;
  margin-bottom: 32rpx;
}

/* 管理员按钮样式 */
.admin-button {
  --td-button-primary-bg-color: var(--admin-primary);
  --td-button-primary-border-color: var(--admin-primary);
}

.admin-button:not(.t-is-disabled):active {
  --td-button-primary-active-bg-color: #7a8bb5;
  --td-button-primary-active-border-color: #7a8bb5;
}

/* TDesign 组件样式覆盖 */
.t-tabs--card .t-tabs__track {
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 4rpx;
}

.t-tabs--card .t-tab-nav__item {
  border-radius: 20rpx;
  font-weight: 500;
}

.t-tabs--card .t-tab-nav__item.t-is-active {
  background: #ffffff;
  color: var(--admin-primary);
  box-shadow: 0 4rpx 16rpx rgba(139, 157, 195, 0.15);
}

.t-card {
  border-radius: 24rpx;
  box-shadow: 0 2rpx 20rpx -4rpx rgba(0, 0, 0, 0.12);
  margin-bottom: 24rpx;
}

.t-card__header {
  padding: 32rpx 32rpx 0 32rpx;
}

.t-card__body {
  padding: 0 32rpx 32rpx 32rpx;
}

.t-tag--primary.t-tag--variant-light {
  background-color: #e6f2ff;
  color: #1a5490;
  border-color: #9cc5f0;
}

.t-tag--success.t-tag--variant-light {
  background-color: #e8f5e8;
  color: #2d5a2d;
  border-color: #a5c9a5;
}

/* 添加测试客户对话框样式 */
.add-test-customer-content {
  padding: 32rpx 0;
}

.test-customer-input-wrapper {
  margin-bottom: 24rpx;
}

.test-customer-input-wrapper:last-child {
  margin-bottom: 0;
}

.test-customer-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fff;
  box-sizing: border-box;
}

.test-customer-input:focus {
  border-color: #d4a574;
  outline: none;
}

.test-customer-input::placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 导出餐单按钮样式 */
.export-menu-card {
  margin-bottom: 24rpx;
}

.export-menu-btn {
  background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
  border: none;
  color: white;
  font-weight: 600;
}

.export-menu-btn[loading] {
  background: #6c757d;
}

.order-stats {
  margin-top: 20rpx;
  padding: 24rpx;
  background: #f9f7f4;
  border-radius: 16rpx;
  color: #5c4630;
  font-size: 24rpx;
  line-height: 1.6;
}

.order-stats .stats-summary {
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.unsubmitted-list {
  border-top: 1rpx dashed rgba(92, 70, 48, 0.2);
  padding-top: 12rpx;
}

.unsubmitted-title {
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.unsubmitted-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #7b5d3f;
  margin-bottom: 6rpx;
  line-height: 1.4;
}

.unsubmitted-item.too-early {
  color: #b07a2d;
}

.unsubmitted-name {
  flex: 1;
  margin-right: 16rpx;
}

.too-early-tag {
  font-size: 20rpx;
  color: #d47b00;
  padding: 2rpx 8rpx;
  background: rgba(212, 123, 0, 0.12);
  border-radius: 8rpx;
}
