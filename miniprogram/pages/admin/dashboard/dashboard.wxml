<view class="page-container">
  <t-calendar
    visible="{{calendarVisible}}"
    value="{{calendarValue}}"
    minDate="{{calendarMinDate}}"
    maxDate="{{calendarMaxDate}}"
    bind:confirm="handleCalendarConfirm"
    bind:close="onCalendarClose"
  />

  <!-- 管理员欢迎区域 -->
  <view class="admin-header">
    <view class="admin-welcome admin-gradient">
      <text class="welcome-title">{{adminHeaderTitle}}</text>
      <text class="welcome-subtitle">{{adminHeaderSubtitle}}</text>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-section">
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-number">{{stats.totalCustomers}}</text>
        <text class="stat-label">在住客户数</text>
      </view>
      <view class="stat-card">
        <text class="stat-number">{{stats.pendingOrders}}</text>
        <text class="stat-label">待确认订单</text>
      </view>
    </view>
  </view>

  <!-- 导航标签 -->
  <view class="tabs-section">
    <t-tabs 
      value="{{activeTab}}" 
      bind:change="onTabChange"
      theme="card"
      space-evenly="{{true}}"
    >
      <t-tab-panel label="订单管理" value="orders">
        <!-- 筛选器 -->
        <view class="filter-section">
          <t-dropdown-menu>
            <t-dropdown-item 
              value="{{selectedOrderStore}}" 
              options="{{storeOptions}}"
              bind:change="onOrderStoreChange"
            />              
          </t-dropdown-menu>
        </view>

        <!-- 日期选择 -->
        <view class="card date-card">
          <t-cell 
            arrow 
            title="选择日期" 
            note="{{selectedDate}}" 
            bind:tap="handleCalendar" 
          />
        </view>

        <!-- 导出餐单按钮 -->
        <view class="card export-menu-card">
          <t-button
            theme="primary"
            size="large"
            block
            bind:tap="exportDailyMenu"
            class="export-menu-btn"
            loading="{{exportingMenu}}"
            disabled="{{isReadOnly}}"
          >
            <text wx:if="{{!exportingMenu}}">导出当日Excel餐单</text>
            <text wx:else>导出中...</text>
          </t-button>

          <view class="order-stats" wx:if="{{orderStats.inhouseCount > 0}}">
            <text class="stats-summary">
              在住客户 {{orderStats.inhouseCount}} 人 · 已提交订单 {{orderStats.submittedCount}} 单
            </text>
            <view class="unsubmitted-list" wx:if="{{orderStats.unsubmittedCustomers.length > 0}}">
              <text class="unsubmitted-title">未提交订单客户：</text>
              <block wx:for="{{orderStats.unsubmittedCustomers}}" wx:key="id">
                <view class="unsubmitted-item {{item.tooEarly ? 'too-early' : ''}}">
                  <text class="unsubmitted-name">{{item.name}}（{{item.room}}）</text>
                  <text wx:if="{{item.tooEarly}}" class="too-early-tag">入住未满7天</text>
                </view>
              </block>
            </view>
          </view>
        </view>

        <!-- 订单列表 -->
        <view class="order-list">
          <view wx:if="{{orderList.length === 0}}" class="empty-state">
            <view class="empty-icon">📋</view>
            <text class="empty-text">暂无订单</text>
            <text class="empty-desc">该日期暂无客户订单</text>
          </view>

          <view 
            wx:for="{{orderList}}" 
            wx:key="id"
            class="card order-item-card"
          >
            <view slot="header" class="order-item-header">
              <view class="customer-info">
                <text class="customer-name">{{item.customerName}} - {{item.room}}</text>
                <text class="submit-time">提交时间: {{item.submitTime}} | {{getStoreText(item.store)}}</text>
              </view>
              <t-tag 
                theme="{{item.status === 'pending' ? 'primary' : 'success'}}"
                variant="light"
                size="small"
              >
                {{item.statusText}}
              </t-tag>
            </view>

            <view class="order-content">
              <view class="order-summary">
                <text class="summary-text">{{item.orderSummary || '暂无订单详情'}}</text>
              </view>

              <view wx:if="{{item.specialRequirements}}" class="special-note">
                <text class="special-label">特殊需求：</text>
                <text class="special-content">{{item.specialRequirements}}</text>
              </view>

              <view class="order-actions" wx:if="{{item.status === 'pending' && !isReadOnly}}">
                <t-button 
                  theme="primary"
                  size="small"
                  bind:tap="confirmOrder"
                  data-id="{{item.id}}"
                  class="admin-button"
                >
                  确认订单
                </t-button>
                <t-button 
                  theme="light"
                  size="small"
                  bind:tap="editOrder"
                  data-id="{{item.id}}"
                >
                  修改订单
                </t-button>
              </view>
            </view>
          </view>
        </view>
      </t-tab-panel>

      <t-tab-panel label="门店餐单管理" value="menus">
        <view class="card portal-card">
          <view class="card-header">
            <text class="card-title">门店餐单管理</text>
          </view>
          <view class="card-body">
            <text class="portal-desc">
              统一维护各门店的餐单轮换起始日期、起始日与结束日。员工可查看，管理员可编辑保存。
            </text>
            <t-button
              theme="primary"
              size="large"
              block
              bind:tap="openMenuManage"
            >
              进入门店餐单管理
            </t-button>
          </view>
        </view>
      </t-tab-panel>

      <t-tab-panel label="客户管理" value="customers">
        <!-- 筛选器 -->
        <view class="filter-section">
          <t-dropdown-menu>
            <t-dropdown-item 
              value="{{selectedCustomerStore}}" 
              options="{{storeOptions}}"
              bind:change="onCustomerStoreChange"
            />
          </t-dropdown-menu>
        </view>

        <!-- 添加客户按钮 -->
        <view class="customer-actions">
          <t-button
            theme="primary"
            size="large"
            block
            bind:tap="addCustomer"
            class="add-customer-btn admin-button"
            disabled="{{isReadOnly}}"
          >
            添加新客户
          </t-button>
          
          <t-button
            theme="light"
            size="large"
            block
            bind:tap="addTestCustomer"
            class="admin-button"
            wx:if="{{false}}"
          >
            添加测试客户
          </t-button>
        </view>

        <!-- 客户列表 -->
        <view class="customer-list">
          <view 
            wx:for="{{customerList}}" 
            wx:key="id"
            class="card customer-item-card"
          >
            <view class="customer-item">
              <view class="customer-main-info">
                <text class="customer-name">{{item.name}}</text>
                <text class="customer-details">{{item.phone}} | {{item.room}} | {{getStoreText(item.store)}}</text>
                <text class="customer-checkin">入住: {{item.checkInDate}} | {{item.totalDays}}</text>
              </view>
              <view class="customer-actions">
                <t-button
                  wx:if="{{!isReadOnly}}"
                  theme="light"
                  size="small"
                  bind:tap="editCustomer"
                  data-id="{{item.id}}"
                >
                  编辑
                </t-button>
                <t-button
                  wx:if="{{!isReadOnly}}"
                  theme="danger"
                  size="small"
                  bind:tap="deleteCustomer"
                  data-id="{{item.id}}"
                  data-name="{{item.name}}"
                  class="delete-customer-btn"
                >
                  删除
                </t-button>
              </view>
            </view>
          </view>
        </view>
      </t-tab-panel>

      <t-tab-panel label="个人中心" value="profile">
        <!-- 管理员信息 -->
        <view class="card admin-info-card">
          <text class="card-title">管理员信息</text>
          <view class="card-body">
          <t-cell-group>
            <t-cell 
              title="姓名" 
              note="{{adminInfo.name || '管理员'}}"
            />
            <t-cell 
              title="角色" 
              note="{{adminInfo.role || '系统管理员'}}"
            />
            <t-cell 
              title="登录时间" 
              note="{{adminInfo.loginTime || '刚刚'}}"
            />
            <t-cell 
              title="权限级别" 
              note="{{adminInfo.permissions || '超级管理员'}}"
            />
          </t-cell-group>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="profile-actions">
          <t-button
            theme="danger"
            size="large"
            block
            bind:tap="logout"
          >
            退出登录
          </t-button>
        </view>
      </t-tab-panel>
    </t-tabs>
  </view>
</view>

<!-- 添加测试客户弹窗 -->
<t-dialog
  visible="{{addTestCustomerVisible}}"
  title="添加测试客户"
  confirm-btn="创建客户"
  cancel-btn="取消"
  bind:confirm="confirmAddTestCustomer"
  bind:cancel="closeAddTestCustomerDialog"
>
  <view slot="content" class="add-test-customer-content">
    <view class="test-customer-input-wrapper">
      <input
        type="text"
        placeholder="请输入客户姓名"
        value="{{testCustomerName}}"
        bindinput="onTestCustomerNameChange"
        class="test-customer-input"
      />
    </view>
    <view class="test-customer-input-wrapper">
      <input
        type="number"
        placeholder="请输入手机号"
        value="{{testCustomerPhone}}"
        bindinput="onTestCustomerPhoneChange"
        class="test-customer-input"
      />
    </view>
  </view>
</t-dialog>

<t-toast id="t-toast" />
