.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, var(--brand-bg-primary) 0%, var(--brand-bg-secondary) 100%);
  display: flex;
  flex-direction: column;
  padding: 32rpx 48rpx 24rpx 48rpx;
  box-sizing: border-box;
  justify-content: space-between;
}

/* Logo区域 */
.logo-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  min-height: 0;
}

.logo-wrapper {
  margin-bottom: 32rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(212, 165, 116, 0.25);
}

.logo-text {
  color: #ffffff;
  font-size: 60rpx;
  font-weight: 300;
  letter-spacing: 4rpx;
}

.brand-info {
  text-align: center;
}

.brand-title {
  display: block;
  font-size: 44rpx;
  font-weight: 400;
  color: var(--brand-text);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.brand-slogan {
  display: block;
  font-size: 28rpx;
  color: var(--brand-text-secondary);
  letter-spacing: 1rpx;
}

/* 登录区域 */
.login-section {
  margin-bottom: 32rpx;
  flex-shrink: 0;
}

.login-button {
  margin-bottom: 24rpx;
  --td-button-default-height: 88rpx;
  --td-button-large-font-size: 32rpx;
  --td-button-border-radius: 44rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  box-shadow: 0 6rpx 20rpx rgba(212, 165, 116, 0.3);
  
  /* 覆盖 TDesign 默认的蓝色主题，使用爱睦品牌色 */
  --td-button-primary-bg-color: var(--brand-primary) !important;
  --td-button-primary-border-color: var(--brand-primary) !important;
  --td-button-primary-color: #ffffff !important;
  --td-button-primary-active-bg-color: var(--brand-primary-dark) !important;
  --td-button-primary-active-border-color: var(--brand-primary-dark) !important;
  --td-button-primary-disabled-bg-color: var(--brand-primary-light) !important;
  --td-button-primary-disabled-border-color: var(--brand-primary-light) !important;
  
  /* 添加渐变背景效果 */
  background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-primary-light) 100%) !important;
  border: none !important;
  
  /* 按下时的效果 */
  transition: all 0.3s ease !important;
}

.login-button:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 15rpx rgba(212, 165, 116, 0.4);
  background: linear-gradient(135deg, var(--brand-primary-dark) 0%, var(--brand-primary) 100%) !important;
}

.tip-section {
  display: flex;
  justify-content: center;
}

.tip-card {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  padding: 24rpx;
  border-left: 6rpx solid #fbbf24;
  max-width: 100%;
}

.tip-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--brand-text);
  margin-bottom: 16rpx;
}

.tip-content {
  display: block;
  font-size: 24rpx;
  color: var(--brand-text);
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.tip-content:last-child {
  margin-bottom: 0;
}

/* 底部区域 */
.footer-section {
  text-align: center;
  flex-shrink: 0;
  margin-top: auto;
}

.footer-text {
  font-size: 24rpx;
  color: var(--brand-text-secondary);
  line-height: 1.5;
}

.link-text {
  color: var(--brand-primary);
  text-decoration: underline;
}

.demo-info {
  background: rgba(212, 165, 116, 0.1);
  border: 2rpx solid var(--brand-primary-light);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 24rpx;
  text-align: left;
}

.demo-title {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--brand-primary);
  margin-bottom: 12rpx;
}

.demo-content {
  display: block;
  font-size: 22rpx;
  color: var(--brand-text-secondary);
  margin-bottom: 6rpx;
}

.demo-item {
  display: block;
  font-size: 22rpx;
  color: var(--brand-text-secondary);
  line-height: 1.4;
  margin-bottom: 3rpx;
}

/* 弹窗内容 */
.admin-verify-content {
  padding: 32rpx 0;
  min-height: 120rpx;
}

.admin-input-wrapper {
  margin-bottom: 24rpx;
  width: 100%;
  display: block;
}

.input-label {
  font-size: 28rpx;
  color: var(--brand-text);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.admin-password-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.admin-password-input:focus {
  border-color: var(--brand-primary);
  outline: none;
}

.admin-verify-tip {
  font-size: 24rpx;
  color: var(--brand-text-secondary);
  line-height: 1.5;
  display: block;
  text-align: center;
}

/* 响应式设计 - 针对不同屏幕尺寸 */

/* 小屏手机 (iPhone SE, 小屏 Android) */
@media (max-height: 667px) {
  .login-container {
    padding: 24rpx 40rpx 16rpx 40rpx;
  }
  
  .logo {
    width: 160rpx;
    height: 160rpx;
  }
  
  .logo-text {
    font-size: 48rpx;
  }
  
  .brand-title {
    font-size: 36rpx;
  }
  
  .brand-slogan {
    font-size: 24rpx;
  }
  
  .logo-wrapper {
    margin-bottom: 24rpx;
  }
  
  .logo-section {
    margin-bottom: 32rpx;
  }
  
  .login-section {
    margin-bottom: 24rpx;
  }
  
  .login-button {
    --td-button-default-height: 80rpx;
    --td-button-large-font-size: 28rpx;
  }
  
  .demo-info {
    padding: 16rpx;
    margin-top: 16rpx;
  }
  
  .demo-title,
  .demo-content,
  .demo-item {
    font-size: 20rpx;
  }
}

/* 超小屏手机 */
@media (max-height: 568px) {
  .login-container {
    padding: 16rpx 32rpx 12rpx 32rpx;
  }
  
  .logo {
    width: 140rpx;
    height: 140rpx;
  }
  
  .logo-text {
    font-size: 40rpx;
  }
  
  .brand-title {
    font-size: 32rpx;
  }
  
  .brand-slogan {
    font-size: 22rpx;
  }
  
  .logo-wrapper {
    margin-bottom: 16rpx;
  }
  
  .logo-section {
    margin-bottom: 24rpx;
  }
  
  .login-section {
    margin-bottom: 16rpx;
  }
  
  .login-button {
    margin-bottom: 16rpx;
    --td-button-default-height: 72rpx;
    --td-button-large-font-size: 26rpx;
  }
  
  .tip-card {
    padding: 16rpx;
  }
  
  .tip-title {
    font-size: 20rpx;
    margin-bottom: 8rpx;
  }
  
  .tip-content {
    font-size: 20rpx;
  }
  
  .demo-info {
    padding: 12rpx;
    margin-top: 12rpx;
  }
  
  .demo-title,
  .demo-content,
  .demo-item {
    font-size: 18rpx;
    line-height: 1.3;
  }
}

/* 大屏手机 (iPhone Plus, 大屏 Android) */
@media (min-height: 812px) {
  .login-container {
    padding: 80rpx 64rpx 40rpx 64rpx;
  }
  
  .logo {
    width: 240rpx;
    height: 240rpx;
  }
  
  .logo-text {
    font-size: 68rpx;
  }
  
  .brand-title {
    font-size: 48rpx;
  }
  
  .brand-slogan {
    font-size: 30rpx;
  }
  
  .logo-wrapper {
    margin-bottom: 40rpx;
  }
  
  .logo-section {
    margin-bottom: 64rpx;
  }
  
  .login-section {
    margin-bottom: 48rpx;
  }
  
  .login-button {
    margin-bottom: 32rpx;
    --td-button-default-height: 96rpx;
    --td-button-large-font-size: 34rpx;
  }
}
