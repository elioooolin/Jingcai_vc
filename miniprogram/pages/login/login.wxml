<view class="login-container">
  <!-- 品牌Logo区域 -->
  <view class="logo-section">
    <view class="logo-wrapper">
      <image 
        class="logo-image" 
        src="/assets/icons/logo_reverse_lm.svg" 
        mode="aspectFit"
      />
    </view>
    
    <view class="brand-info">
      <text class="brand-title">爱睦月子餐</text>
      <text class="brand-slogan">轻松呵护 · 用心滋养</text>
    </view>
  </view>

  <!-- 登录按钮 -->
  <view class="login-section">
    <t-button
      theme="primary"
      size="large"
      block
      loading="{{loginLoading}}"
      bind:tap="handleWechatLogin"
      class="login-button"
    >
      <text wx:if="{{!loginLoading}}">微信一键登录</text>
      <text wx:else>登录中...</text>
    </t-button>
  </view>

  <!-- 底部信息 -->
  <view class="footer-section">
    <text class="footer-text">
      登录即表示同意<text class="link-text" bind:tap="showUserAgreement">用户协议</text>和<text class="link-text" bind:tap="showPrivacyPolicy">隐私政策</text>
    </text>
  </view>
</view>

<!-- 用户不存在弹窗 -->
<t-dialog
  visible="{{userNotFoundVisible}}"
  title="用户不存在"
  content="{{userNotFoundContent}}"
  confirm-btn="我知道了"
  bind:confirm="closeUserNotFoundDialog"
  bind:close="closeUserNotFoundDialog"
/>

<!-- 管理员验证弹窗 -->
<t-dialog
  visible="{{adminVerifyVisible}}"
  title="管理员身份验证"
  confirm-btn="验证并登录"
  cancel-btn="取消"
  bind:confirm="verifyAdminPassword"
  bind:cancel="closeAdminVerifyDialog"
>
  <view class="admin-verify-content">
    <t-input
      label="管理员密码"
      type="password"
      placeholder="请输入管理员密码"
      value="{{adminPassword}}"
      bind:change="onAdminPasswordChange"
      class="admin-password-input"
    />
    <text class="admin-verify-tip">请输入管理员专用密码以访问后台管理系统</text>
  </view>
</t-dialog>

<!-- 用户协议弹窗 -->
<t-dialog
  visible="{{userAgreementVisible}}"
  title="用户协议"
  content="{{userAgreementContent}}"
  confirm-btn="我知道了"
  bind:confirm="closeUserAgreementDialog"
  bind:close="closeUserAgreementDialog"
/>

<!-- 隐私政策弹窗 -->
<t-dialog
  visible="{{privacyPolicyVisible}}"
  title="隐私政策"
  content="{{privacyPolicyContent}}"
  confirm-btn="我知道了"
  bind:confirm="closePrivacyPolicyDialog"
  bind:close="closePrivacyPolicyDialog"
/>
