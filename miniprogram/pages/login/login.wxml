<view class="login-container">
  <!-- 品牌Logo区域 -->
  <view class="logo-section">
    <view class="logo-wrapper">
      <image 
        class="logo-image" 
        src="/assets/icons/logo_reverse_lm.svg" 
        mode="aspectFit"
      />
    </view>
    
    <view class="brand-info">
      <text class="brand-title">爱睦 Love Moon</text>
      <text class="brand-slogan">轻松呵护 · 用心滋养</text>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="notice-section">
    <text class="notice-text">本服务仅供爱睦旗下月子中心内部客户使用，登录前请确保您已获得邀请码</text>
  </view>

  <!-- 登录按钮 -->
  <view class="login-section">
    <t-button
      theme="primary"
      size="large"
      block
      loading="{{loginLoading}}"
      bind:tap="handleWechatLogin"
      class="login-button"
    >
      <text wx:if="{{!loginLoading}}">邀请码登录</text>
      <text wx:else>登录中...</text>
    </t-button>
  </view>

  <!-- 底部信息 -->
  <view class="footer-section">
    <text class="footer-text">
      登录即表示同意<text class="link-text" bind:tap="showUserAgreement">用户协议</text>和<text class="link-text" bind:tap="showPrivacyPolicy">隐私政策</text>
    </text>
  </view>
</view>

<!-- 用户不存在弹窗 -->
<t-dialog
  visible="{{userNotFoundVisible}}"
  title="用户不存在"
  content="{{userNotFoundContent}}"
  confirm-btn="我知道了"
  bind:confirm="closeUserNotFoundDialog"
  bind:close="closeUserNotFoundDialog"
/>

<!-- 管理员验证弹窗 -->
<t-dialog
  visible="{{adminVerifyVisible}}"
  title="管理员身份验证"
  confirm-btn="验证并登录"
  cancel-btn="取消"
  bind:confirm="verifyAdminPassword"
  bind:cancel="closeAdminVerifyDialog"
>
  <view slot="content" class="admin-verify-content">
    <view class="admin-input-wrapper">
      <input
        type="password"
        placeholder="请输入管理员密码"
        value="{{adminPassword}}"
        bindinput="onAdminPasswordChange"
        class="admin-password-input"
      />
    </view>
  </view>
</t-dialog>

<!-- 用户协议弹窗 - 微信原生组件 -->
<view class="custom-modal" wx:if="{{userAgreementVisible}}" catchtouchmove="true">
  <view class="modal-mask" bindtap="closeUserAgreementDialog"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">用户协议</text>
    </view>
    <scroll-view scroll-y class="modal-body">
      <text class="modal-text">{{userAgreementContent}}</text>
    </scroll-view>
    <view class="modal-footer">
      <button class="modal-button" bindtap="closeUserAgreementDialog">我知道了</button>
    </view>
  </view>
</view>

<!-- 隐私政策弹窗 - 微信原生组件 -->
<view class="custom-modal" wx:if="{{privacyPolicyVisible}}" catchtouchmove="true">
  <view class="modal-mask" bindtap="closePrivacyPolicyDialog"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">隐私政策</text>
    </view>
    <scroll-view scroll-y class="modal-body">
      <text class="modal-text">{{privacyPolicyContent}}</text>
    </scroll-view>
    <view class="modal-footer">
      <button class="modal-button" bindtap="closePrivacyPolicyDialog">我知道了</button>
    </view>
  </view>
</view>
