{
  "collections": [
    {
      "name": "auth",
      "description": "用户登录凭证表",
      "fields": [
        {
          "name": "_id",
          "type": "string",
          "description": "记录唯一标识"
        },
        {
          "name": "_openid",
          "type": "string",
          "description": "微信openid（自动生成）"
        },
        {
          "name": "phone",
          "type": "string",
          "description": "绑定的手机号码（唯一）"
        },
        {
          "name": "createdAt",
          "type": "date",
          "description": "创建时间"
        },
        {
          "name": "updatedAt",
          "type": "date",
          "description": "更新时间"
        }
      ],
      "indexes": [
        {
          "fields": ["phone"],
          "unique": true
        }
      ]
    },
    {
      "name": "users",
      "description": "用户详细信息表（由管理员预先创建）",
      "fields": [
        {
          "name": "_id",
          "type": "string",
          "description": "用户唯一标识"
        },
        {
          "name": "phone",
          "type": "string",
          "description": "手机号码（关联auth表）"
        },
        {
          "name": "name",
          "type": "string",
          "description": "用户姓名"
        },
        {
          "name": "role",
          "type": "string",
          "description": "角色：admin/staff/customer"
        },
        {
          "name": "userType",
          "type": "string",
          "description": "用户类型：customer/admin"
        },
        {
          "name": "isAdmin",
          "type": "boolean",
          "description": "是否为管理员"
        },
        {
          "name": "status",
          "type": "string",
          "description": "用户状态：active/inactive/pending"
        },
        {
          "name": "room",
          "type": "string",
          "description": "房间号（客户专用）"
        },
        {
          "name": "checkInDate",
          "type": "date",
          "description": "入住日期（客户专用）"
        },
        {
          "name": "birthday",
          "type": "date",
          "description": "用户生日"
        },
        {
          "name": "totalDays",
          "type": "number",
          "description": "入住天数"
        },
        {
          "name": "store",
          "type": "string",
          "description": "入住门店（meixihu/desiqin）"
        },
        {
          "name": "dietPreference",
          "type": "string",
          "description": "饮食偏好"
        },
        {
          "name": "supplementCount",
          "type": "number",
          "description": "高补餐次数"
        },
        {
          "name": "freeFamilyMealCount",
          "type": "number",
          "description": "免费陪人餐次数"
        },
        {
          "name": "createdBy",
          "type": "string",
          "description": "创建者（管理员ID）"
        },
        {
          "name": "createdAt",
          "type": "date",
          "description": "创建时间"
        },
        {
          "name": "updatedAt",
          "type": "date",
          "description": "更新时间"
        }
      ],
      "indexes": [
        {
          "fields": ["phone"],
          "unique": true
        }
      ]
    },
    {
      "name": "menu_rotation_configs",
      "description": "门店菜单轮换配置表",
      "fields": [
        {
          "name": "_id",
          "type": "string",
          "description": "配置唯一标识"
        },
        {
          "name": "store",
          "type": "string",
          "description": "门店名称"
        },
        {
          "name": "menu_start_date",
          "type": "date",
          "description": "该门店轮换起始日期，对应 start_day"
        },
        {
          "name": "start_day",
          "type": "number",
          "description": "轮换起始菜单天数"
        },
        {
          "name": "end_day",
          "type": "number",
          "description": "轮换结束菜单天数"
        },
        {
          "name": "status",
          "type": "string",
          "description": "配置状态：active/inactive"
        },
        {
          "name": "updatedAt",
          "type": "date",
          "description": "更新时间"
        },
        {
          "name": "updatedBy",
          "type": "string",
          "description": "更新人"
        }
      ],
      "indexes": [
        {
          "fields": ["store"],
          "unique": true
        }
      ]
    },
    {
      "name": "orders",
      "description": "订单信息表",
      "fields": [
        {
          "name": "_id",
          "type": "string",
          "description": "订单唯一标识"
        },
        {
          "name": "userId",
          "type": "string",
          "description": "用户ID（关联users表）"
        },
        {
          "name": "phone",
          "type": "string",
          "description": "用户手机号"
        },
        {
          "name": "store",
          "type": "string",
          "description": "门店信息"
        },
        {
          "name": "orderDate",
          "type": "date",
          "description": "订单日期"
        },
        {
          "name": "order_details",
          "type": "object"
        },
        {
          "name": "status",
          "type": "string",
          "description": "订单状态：pending/confirmed/preparing/completed/cancelled"
        },
        {
          "name": "createdAt",
          "type": "date",
          "description": "创建时间"
        },
        {
          "name": "updatedAt",
          "type": "date",
          "description": "更新时间"
        }
      ]
    },
    {
      "name": "user_sessions",
      "description": "登录会话表（Plan B 会话模式）",
      "fields": [
        {
          "name": "_id",
          "type": "string",
          "description": "会话唯一标识"
        },
        {
          "name": "sessionToken",
          "type": "string",
          "description": "客户端持有的随机会话令牌"
        },
        {
          "name": "openid",
          "type": "string",
          "description": "本次登录对应的微信 openid"
        },
        {
          "name": "userId",
          "type": "string",
          "description": "关联的 users._id；visitor 可为空"
        },
        {
          "name": "phone",
          "type": "string",
          "description": "本次登录使用的手机号"
        },
        {
          "name": "role",
          "type": "string",
          "description": "角色：admin/staff/customer/visitor"
        },
        {
          "name": "isRegistered",
          "type": "boolean",
          "description": "是否匹配到已登记用户"
        },
        {
          "name": "isActive",
          "type": "boolean",
          "description": "会话是否有效"
        },
        {
          "name": "createdAt",
          "type": "date",
          "description": "创建时间"
        },
        {
          "name": "updatedAt",
          "type": "date",
          "description": "更新时间"
        },
        {
          "name": "expiresAt",
          "type": "date",
          "description": "过期时间"
        }
      ],
      "indexes": [
        {
          "fields": ["sessionToken"],
          "unique": true
        }
      ]
    }
  ]
}
